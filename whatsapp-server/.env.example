# IDCS WhatsApp Gateway – environment variables
# Copy this file to .env and fill in your values.

# Port to listen on (default: 3000)
PORT=3000

# Secret API key – must match OBE_WHATSAPP_API_KEY in the Django backend .env
# Generate a strong random string, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WA_API_KEY=change-me-to-a-strong-secret-key

# Directory where WhatsApp session data is stored (default: ./.wwebjs_auth)
# Ensure this path is writable and persistent (excluded from git, included in backups).
WA_SESSION_DIR=./.wwebjs_auth

# Optional: path to a specific Chrome/Chromium executable.
# Leave blank to let Puppeteer use its bundled browser.
# CHROME_PATH=/usr/bin/google-chrome-stable
