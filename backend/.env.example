# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
# Optional explicit key for field-level encryption of stored credentials/tokens.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Production DB only (PostgreSQL)
DB_NAME=
DB_USER=
DB_PASS=
DB_HOST=
DB_PORT=5432

# Email Configuration (for password reset, notifications)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password

# AWS S3 Configuration (if using S3 for media/static files)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# CORS / CSRF origin settings
# Production: set only deployed UI origins (comma-separated).
CORS_ALLOWED_ORIGINS=https://idcs.krgi.co.in,https://db.krgi.co.in
CSRF_TRUSTED_ORIGINS=https://idcs.krgi.co.in,https://db.krgi.co.in
# Optional debug-only additions (applied only when DEBUG=True)
CORS_DEV_EXTRA_ORIGINS=
CSRF_DEV_EXTRA_ORIGINS=

# Frontend URL
FRONTEND_URL=http://localhost:5173

# WhatsApp Integration (if applicable)
WHATSAPP_API_KEY=
WHATSAPP_API_URL=

# Other API Keys
CANVA_API_KEY=

# Staff biometric realtime security (used by /api/staff-attendance/biometric/realtime/)
STAFF_BIOMETRIC_INGEST_KEY=change-this-to-a-long-random-token

# eSSL biometric device defaults (used by sync_essl_realtime command)
ESSL_DEVICE_IP=192.168.81.80
ESSL_DEVICE_PORT=4370
ESSL_DEVICE_PASSWORD=0
ESSL_CONNECT_TIMEOUT=8
ESSL_RECONNECT_DELAY=5
